#
# Standalone Dockerfile for vllm-qaic in AOT (Ahead-of-Time) mode.
#
# AOT mode uses the QEfficient compiler to compile models to .qpc
# artifacts ahead of serving. It requires torch==2.7.0+cpu and
# must NOT have torch_qaic installed in the same environment.
#
# Build (run from the vllm-qaic repo root):
#   docker build -f docker/Dockerfile.aot \
#     -t vllm-qaic-aot:latest .
#
# Override the base image if needed:
#   docker build -f docker/Dockerfile.aot \
#     --build-arg BASE_IMAGE=ghcr.io/quic/cloud_ai_inference_ubuntu24:1.21.6.0 \
#     -t vllm-qaic-aot:latest .
#
# The BASE_IMAGE must have the QAIC Platform and Apps SDKs installed
# (i.e. /opt/qti-aic/ present) so that vllm-qaic can load at runtime.
#
# To verify after build:
#   docker run --rm vllm-qaic-aot:latest python -c \
#     "import torch; print(torch.__version__); import vllm_qaic; print('OK')"
# ------------------------------------------------------------------

ARG BASE_IMAGE="ghcr.io/quic/cloud_ai_inference_ubuntu24:1.21.6.0"
ARG VENV="/opt/venv-aot"

# ---------------------------------------------------------------------------
# Stage 1: Build the full AOT Python environment on top of the SDK base image.
#   - Using BASE_IMAGE (Ubuntu 24.04) ensures /opt/qti-aic/tools/qaic-util
#     is present, which setup.py's _is_qaic() check requires.
#   - No torch_qaic in this env — setup.py detects AOT mode automatically.
#   - Only the finished venv is retained in the final stage.
# ---------------------------------------------------------------------------
# hadolint ignore=DL3006
FROM ${BASE_IMAGE} AS aot_venv_builder

ARG VENV
ARG PIP_CACHE_DIR="/var/cache/pip"

# 1a. Build-time tools required for --no-build-isolation installs.
RUN --mount=type=cache,sharing=locked,target=/var/cache/apt \
    --mount=type=cache,sharing=locked,target=/var/lib/apt \
    apt-get update && apt-get install -y --no-install-recommends \
        python3.12-venv

# Create the target venv.
RUN python3.12 -m venv ${VENV}
ENV PATH="${VENV}/bin:${PATH}"

# 1b–1f. Delegate the full AOT install sequence to install.sh, which handles:
#   QEfficient → torch==2.7.0+cpu re-pin → vllm deps → vllm → vllm-qaic.
#   VLLM_VERSION_OVERRIDE bypasses get_qaic_sdk_version() to prevent
#   libQAic.so's stdout output from corrupting pip's version capture.
#   TORCH_QAIC_INSTALLED=0 prevents setup.py from detecting PYT mode.
COPY . /src/vllm-qaic
RUN --mount=type=cache,sharing=locked,target=${PIP_CACHE_DIR} \
    VIRTUAL_ENV="${VENV}" \
    VLLM_VERSION_OVERRIDE="0.15.0+aot1.22" \
    bash /src/vllm-qaic/scripts/install.sh aot

# ---------------------------------------------------------------------------
# Stage 2: Runtime image.
#   Start fresh from BASE_IMAGE and drop in only the finished venv,
#   leaving behind any intermediate build artefacts.
# ---------------------------------------------------------------------------
# hadolint ignore=DL3006
FROM ${BASE_IMAGE} AS final

ARG VENV

COPY --from=aot_venv_builder ${VENV} ${VENV}

ENV PATH="${VENV}/bin:${PATH}"

# Tell vLLM to load the QAIC platform plugin on startup.
ENV VLLM_PLUGINS="qaic"
